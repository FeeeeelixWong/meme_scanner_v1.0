# OKX Web3 API credentials.
OKX_API_KEY="replace-me"
OKX_SECRET_KEY="replace-me"
OKX_PASSPHRASE="replace-me"

# Solana wallet private key in Base58 format. Use a dedicated low-balance bot wallet.
WALLET_PRIVATE_KEY="replace-me"

# Safety default: keep this at 0 for observation/dry-run mode.
# Set to 1 only when you intentionally want the bot to sign and broadcast swaps.
ENABLE_LIVE_TRADING=0

# Dashboard binds to localhost by default. Use 0.0.0.0 only if you know the network risk.
DASHBOARD_HOST=127.0.0.1
